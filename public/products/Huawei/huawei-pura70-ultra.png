<style>
    @media (min-width: 1024px){
        .huawei-v3 .header-wrap .right-box .search-wrap{  width: inherit!important;height: inherit!important;margin-top: 0!important;}
        .huawei-v3 .header-wrap .right-box .search-wrap .a-common{ display: none!important;  }
        .huawei-v3 .header-wrap-v3 .right-box .login-v3{   margin-left: 0!important; }
    }

    .huawei-v3 .error{height: 460px;background: #f3f3f3;}
    .huawei-v3 .error .error-wrap{width: 1024px;margin: 0 auto;text-align: center;}
    .huawei-v3 .error .error-tit{font-size: 48px;font-weight: 700;text-align: center;line-height: 54px;    padding: 85px 20px 0;}
    .huawei-v3 .error .error-ipt-wrap{margin-top: 85px;position: relative;display: inline-block;}
    .huawei-v3 .error .error-ipt-wrap input{width: 688px;height: 52px;line-height: 52px;border: 1px solid #aaaaaa;padding: 0 62px;margin: 0 auto;background: #ffffff;display: block;    border-radius: 8px;font-size: 16px;}
    .huawei-v3 .error .error-ipt-wrap input::-webkit-input-placeholder { color: #8e8e8e; font-size: 16px;}
    .huawei-v3 .error .error-ipt-wrap input:-moz-placeholder { color: #8e8e8e; font-size: 16px; }
    .huawei-v3 .error .error-ipt-wrap input::-moz-placeholder { color: #8e8e8e; font-size: 16px; }
    .huawei-v3 .error .error-ipt-wrap input:-ms-input-placeholder { color: #8e8e8e; font-size: 16px; }
    .huawei-v3 .error .error-seach{    display: block;position: absolute;top: 50%;left: 20px;height: 24px;margin-top: -12px;}
    .huawei-v3 .error .error-bnt{ display: block;   width: 24px;height: 24px;position: absolute;background: url('/.resources/huawei-cbg-site-lm-basic/webresources/mkt/etc/designs/huawei-cbg-site/clientlib-v3/images/v3-icon.svg') no-repeat -248px -243px;top: 50%;right: 20px;margin-top: -12px;}
    .huawei-v3 .error .home-wrap{padding-top: 28px;font-size: 16px;text-align: center; font-weight: 300;    color: #030303;}
    .huawei-v3 .error .home-wrap a{    border-bottom: 1px solid #030303;color: #030303;}
    .huawei-v3 .error .home-wrap a:hover{color: #d20a2c;border-bottom-color: #d20a2c;}


    /* v4  page-not-found */
    .v4 .error .error-seach:before {font-family: 'svgicons';-webkit-font-smoothing: antialiased;-moz-osx-font-smoothing: grayscale;font-style: normal;font-variant: normal;font-weight: normal;text-decoration: none;text-transform: none;display: block;line-height: 1;content: "\e01e";}
    .v4 .huawei-v3 .error .error-ipt-wrap input{width: 814px;height: 72px;padding: 20px 80px 20px 32px;border-radius: 36px;border: 1px solid rgba(0,0,0,0.2);font-size: 26px;font-weight: 400;color: #000;letter-spacing: -0.5px;line-height: 30px;-webkit-transition: .3s ease-out;transition: .3s ease-out;font-family: "Manrope",Arial,Helvetica Neue,Helvetica,sans-serif;}
    .v4 .huawei-v3 .error .error-seach{position: absolute;top: 5px;left: inherit;right: 14px;width: 60px;height: 60px;margin: 0;border-radius: 50%;font-size: 22px;color: #7f7f7f;display: flex;justify-content: center;align-items: center;cursor: pointer;}
    .v4 .huawei-v3 .error .error-seach svg{display: none;}
    .v4 .huawei-v3 .error .error-bnt{display: none;}
    .v4 .huawei-v3 .error .error-ipt-wrap input::-webkit-input-placeholder {color: #7f7f7f;font-size: 26px;}
    .v4 .huawei-v3 .error .error-ipt-wrap input:-moz-placeholder {color: #7f7f7f;font-size: 26px;}
    .v4 .huawei-v3 .error .error-ipt-wrap input::-moz-placeholder {color: #7f7f7f;font-size: 26px;}
    .v4 .huawei-v3 .error .error-ipt-wrap input:-ms-input-placeholder {color: #7f7f7f;font-size: 26px;}
    html[dir=rtl]  .v4 .huawei-v3 .error .error-seach{left: 14px;right: inherit;}
    html[dir=rtl] .v4 .huawei-v3 .error .error-ipt-wrap input{padding: 20px 32px 20px 80px;}
    @media (max-width: 1023px){
        .huawei-v3 .header-wrap .app-search{display: none!important;}
        .huawei-v3 .error{height: 515px;}
        .huawei-v3 .error .error-wrap{width: 100%;}
        .huawei-v3 .error .error-tit{font-size: 40px;line-height: 46px;padding: 100px 20px 0;}
        .huawei-v3 .error .error-ipt-wrap{width: 80%;margin: 90px auto 0;}
        .huawei-v3 .error .error-ipt-wrap input{width:calc(100% - 80px);padding: 0 40px;font-size: 15px;}
        .huawei-v3 .error .error-ipt-wrap input::-webkit-input-placeholder { color: #8e8e8e; font-size: 15px;}
        .huawei-v3 .error .error-ipt-wrap input:-moz-placeholder { color: #8e8e8e; font-size: 15px; }
        .huawei-v3 .error .error-ipt-wrap input::-moz-placeholder { color: #8e8e8e; font-size: 15px; }
        .huawei-v3 .error .error-ipt-wrap input:-ms-input-placeholder { color: #8e8e8e; font-size: 15px; }
        .huawei-v3 .error .error-seach{    left: 10px;}
        .huawei-v3 .error .error-bnt{    right: 10px;}
        .huawei-v3 .error .home-wrap{padding: 50px 20px 0;}
        .v4 .huawei-v3 .error .error-ipt-wrap input{width:100%;}
    }
    @media (max-width: 767px) {
        .v4 .huawei-v3 .error .error-seach{    width: 44px;height: 44px;right: 6px;}
        html[dir=rtl]  .v4 .huawei-v3 .error .error-seach{left: 6px;right: inherit;}
        .v4 .huawei-v3 .error .error-ipt-wrap input{  height: 56px;padding: 12px 50px 12px 24px;border-radius: 28px;font-size: 20px;}
        html[dir=rtl] .v4 .huawei-v3 .error .error-ipt-wrap input{ padding: 12px 24px 12px 50px;}
        .v4 .huawei-v3 .error .error-ipt-wrap input::-webkit-input-placeholder {font-size: 20px;}
        .v4 .huawei-v3 .error .error-ipt-wrap input:-moz-placeholder {font-size: 20px;}
        .v4 .huawei-v3 .error .error-ipt-wrap input::-moz-placeholder {font-size: 20px;}
        .v4 .huawei-v3 .error .error-ipt-wrap input:-ms-input-placeholder {font-size: 20px;}

    }
    @media (max-width: 320px){
        .huawei-v3 .error .error-ipt-wrap input{width:calc(100% - 80px);padding: 0 40px;font-size: 12px;}
        .huawei-v3 .error .error-ipt-wrap input::-webkit-input-placeholder { color: #8e8e8e; font-size: 12px;}
        .huawei-v3 .error .error-ipt-wrap input:-moz-placeholder { color: #8e8e8e; font-size: 12px; }
        .huawei-v3 .error .error-ipt-wrap input::-moz-placeholder { color: #8e8e8e; font-size: 12px; }
        .huawei-v3 .error .error-ipt-wrap input:-ms-input-placeholder { color: #8e8e8e; font-size: 12px; }
    }
</style>
